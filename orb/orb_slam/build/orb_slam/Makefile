	$(MAKE) $(MAKESILENT) -f CMakeFiles/orb_slam.dir/build.make CMakeFiles/orb_slam.dir/src/Tracking.cc.i
.PHONY : src/Tracking.cc.i

src/Tracking.s: src/Tracking.cc.s
.PHONY : src/Tracking.s

# target to generate assembly for a file
src/Tracking.cc.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/orb_slam.dir/build.make CMakeFiles/orb_slam.dir/src/Tracking.cc.s
.PHONY : src/Tracking.cc.s

src/main.o: src/main.cc.o
.PHONY : src/main.o

# target to build an object file
src/main.cc.o:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/orb_slam.dir/build.make CMakeFiles/orb_slam.dir/src/main.cc.o
.PHONY : src/main.cc.o

src/main.i: src/main.cc.i
.PHONY : src/main.i

# target to preprocess a source file
src/main.cc.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/orb_slam.dir/build.make CMakeFiles/orb_slam.dir/src/main.cc.i
.PHONY : src/main.cc.i

